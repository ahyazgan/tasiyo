# Android RELEASE imzalama yapılandırması — ŞABLON
#
# 1) Bu dosyayı "keystore.properties" adıyla kopyala (android/ klasöründe).
# 2) Aşağıdaki değerleri kendi keystore bilgilerinle doldur.
# 3) keystore.properties ve *.keystore dosyaları .gitignore'da — ASLA commit etme.
#
# Keystore oluşturma (bir kez — güvenli sakla, kaybedersen güncelleme yayınlayamazsın):
#   keytool -genkey -v -keystore android/dayim-upload.keystore \
#     -alias dayim -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile yolu android/ klasörüne göredir (rootProject).

storeFile=dayim-upload.keystore
storePassword=BURAYA_KEYSTORE_SIFRESI
keyAlias=dayim
keyPassword=BURAYA_ANAHTAR_SIFRESI
